{
  "name": "@holi.dev/schema",
  "version": "0.1.1",
  "description": "JSON Schema and validation for Holi config files",
  "keywords": ["holi", "css", "design-tokens", "json-schema", "validation"],
  "license": "MIT",
  "author": "Chandan Bose",
  "repository": { "type": "git", "url": "https://github.com/ChandanBose666/Holi.git" },
  "homepage": "https://github.com/ChandanBose666/Holi#readme",
  "files": ["dist"],
  "engines": { "node": ">=18.0.0" },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "*",
    "tsup": "*",
    "@holi.dev/shared": "*"
  }
}
