{
  "name": "@holi.dev/cli",
  "version": "0.1.0",
  "description": "Zero-runtime CSS compiler CLI — one config file, pure CSS output",
  "keywords": ["holi", "css", "design-tokens", "zero-runtime", "cli", "build-tool"],
  "license": "MIT",
  "author": "Chandan Bose",
  "repository": { "type": "git", "url": "https://github.com/ChandanBose666/Holi.git" },
  "homepage": "https://github.com/ChandanBose666/Holi#readme",
  "files": ["dist", "README.md"],
  "bin": { "holi": "./dist/index.js" },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chokidar": "^4.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.0.0",
    "@holi.dev/core": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "*",
    "tsup": "*",
    "@types/node": "*"
  }
}
